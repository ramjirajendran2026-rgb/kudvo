{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-simplexml": "*",
        "akhan619/laravel-ses-tracking": "^1.0",
        "awcodes/filament-tiptap-editor": "^3.0",
        "aws/aws-php-sns-message-validator": "^1.9",
        "aws/aws-sdk-php": "^3.295",
        "barryvdh/laravel-dompdf": "^2.0",
        "bezhansalleh/filament-language-switch": "^3.1",
        "clicksend/clicksend-php": "^5.0",
        "coderflex/filament-turnstile": "^2.2",
        "fakerphp/faker": "^1.23",
        "filament/actions": "^3.2",
        "filament/filament": "^3.2",
        "filament/forms": "^3.2",
        "filament/notifications": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.2",
        "filament/spatie-laravel-settings-plugin": "^3.2",
        "filament/spatie-laravel-translatable-plugin": "^3.2",
        "flowframe/laravel-trend": "^0.1.5",
        "guava/filament-clusters": "^1.1",
        "guzzlehttp/guzzle": "^7.2",
        "hashids/hashids": "^5.0",
        "ipinfo/ipinfolaravel": "^2.6",
        "jenssegers/agent": "^2.6",
        "lara-zeus/quantity": "^1.0",
        "laravel/cashier": "^15.3",
        "laravel/framework": "^10.10",
        "laravel/horizon": "^5.27",
        "laravel/pulse": "^1.2",
        "laravel/reverb": "@beta",
        "laravel/sanctum": "^3.3",
        "laravel/telescope": "^5.0",
        "laravel/tinker": "^2.8",
        "lasserafn/php-initial-avatar-generator": "^4.3",
        "league/flysystem-aws-s3-v3": "^3.0",
        "mcamara/laravel-localization": "^2.0",
        "mvenghaus/filament-plugin-translatable-inline": "^3.0",
        "nnjeim/world": "^1.1",
        "nyholm/psr7": "^1.8",
        "omar-haris/filament-timezone-field": "^1.0",
        "petercoles/multilingual-country-list": "^1.2",
        "pusher/pusher-php-server": "^7.2",
        "ralphjsmit/laravel-seo": "^1.5",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/eloquent-sortable": "^4.1",
        "spatie/laravel-data": "^3.11",
        "spatie/laravel-medialibrary": "^11.0.0",
        "spatie/laravel-pdf": "^1.5",
        "spatie/laravel-permission": "^6.9",
        "spatie/laravel-settings": "^3.2",
        "spatie/laravel-sitemap": "^7.2",
        "spatie/laravel-translatable": "^6.7",
        "squirephp/currencies-en": "^3.5",
        "stechstudio/filament-impersonate": "^3.9",
        "symfony/psr-http-message-bridge": "^7.0",
        "ysfkaya/filament-phone-input": "^2.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": [
            "pint",
            "bun format"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "prefer-stable": true,
    "minimum-stability": "stable"
}
